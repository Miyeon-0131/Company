# 服务端 API 配置（本地：复制为 .env.local；线上 Vercel：在 Project → Settings → Environment Variables 填入同名变量）

# Claude：任务拆解 + Word 主笔撰写报告
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Tavily：联网搜索（Google/百度 搜索专员）
TAVILY_API_KEY=

# GitHub Token（可选）
GITHUB_TOKEN=

# AI 配图：填入 OpenAI Key 即用 DALL·E 3 生成高质量无文字插画（约 $0.04/张）；
# 不填则尝试免费图源（质量一般，可能不可用）。
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3

# ── 邮件交付：二选一 ────────────────────────────────
# 方式 A（推荐）：Google 登录授权，用户点页面里的「用 Google 登录」即可用自己 Gmail 发信
#   在 Google Cloud Console 创建 OAuth 客户端（类型=Web 应用），
#   授权回调填：
#     本地：http://localhost:3000/api/auth/google/callback
#     线上：https://你的域名.vercel.app/api/auth/google/callback
#   并在 OAuth 同意屏幕添加 gmail.send 范围
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 方式 B：传统 SMTP 授权码兜底（QQ/163 等）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_TO=
